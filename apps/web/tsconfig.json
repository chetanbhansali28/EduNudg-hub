{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./src/*"],
      "@edunudg/ui": ["../../packages/ui/src"],
      "@edunudg/ui/*": ["../../packages/ui/src/*"],
      "@edunudg/tenant": ["../../packages/tenant/src/index.ts"],
      "@edunudg/permissions": ["../../packages/permissions/src/index.ts"],
      "@edunudg/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": ["src", "src/vite-env.d.ts"]
}
