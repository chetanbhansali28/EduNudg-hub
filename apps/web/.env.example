# Supabase Cloud — Dashboard → Project Settings → API (no local Docker)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_DEFAULT_PORTAL=platform

# Optional: apex for real multi-host portals (brand.example.com). Leave unset on *.vercel.app
# so Brand/Franchise/Student use same-origin ?portal=&brand= handoff instead of *.localhost.
# VITE_PORTAL_BASE_DOMAIN=edunudg.com

# Dev server: http://localhost:9000
