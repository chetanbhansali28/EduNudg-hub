{
  "name": "edunudg",
  "version": "0.0.0",
  "private": true,
  "description": "EduNudg multi-tenant franchise learning OS",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "cd apps/web && node_modules/.bin/vite --host",
    "build": "pnpm --filter @edunudg/web build",
    "build:dev": "pnpm --filter @edunudg/web exec vite build --mode development",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:rls": "node scripts/run-rls-tests.mjs",
    "test:e2e": "playwright test",
    "ci:local": "node scripts/ci-local.mjs",
    "audit:schema": "node scripts/audit-schema.mjs",
    "db:push": "supabase db push",
    "functions:deploy": "supabase functions deploy",
    "functions:deploy:whatsapp": "supabase functions deploy whatsapp-otp",
    "functions:deploy:passkey": "supabase functions deploy passkey-verify",
    "functions:deploy:brand-owner": "supabase functions deploy brand-owner-credentials",
    "openspec:init": "openspec init --tools cursor",
    "openspec:update": "openspec update"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1",
    "@playwright/test": "^1.49.1",
    "pg": "^8.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
