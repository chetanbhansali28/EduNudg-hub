# Copy to apps/web/.env — values from Supabase Dashboard → Project Settings → API
# No Docker required; use your hosted project URL (not 127.0.0.1).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_DEFAULT_PORTAL=platform

# Dev app: http://localhost:9000  (pnpm dev)

# Optional — RLS SQL tests (pnpm test:rls). Do not commit. Use repo-root .env.local.
# Easiest after `supabase link` (writes supabase/.temp/pooler-url):
# SUPABASE_DB_PASSWORD=your-database-password
# Or full Session pooler URI (IPv4 — not db.[ref].supabase.co):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional — set OAuth in Supabase Dashboard → Authentication → Providers
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_SECRET=
